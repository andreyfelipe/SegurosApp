@model IEnumerable<SegurosApp.Models.Seguradora>

@{
    ViewData["Title"] = "Index";
}

<h2 class="display-4">Seguradoras</h2>
<div class="d-flex justify-content-between align-items-center mb-3">
    <p>
        <a asp-action="Create" class="btn btn-primary">Criar Nova</a>
    </p>
</div>



<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.Nome)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Cnpj)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Telefone)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Email)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Ativa)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Seguros)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(model => item.Nome)
                            </td>
                            <td>
                                @Html.DisplayFor(model => item.Cnpj)
                            </td>
                            <td>
                                @Html.DisplayFor(model => item.Telefone)
                            </td>
                            <td>
                                @Html.DisplayFor(model => item.Email)
                            </td>
                            <td>
                                @Html.DisplayFor(model => item.Ativa)
                            </td>
                            <td>
                                @Html.DisplayFor(model => item.Seguros)
                            </td>
                            <td>
                                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Editar</a>
                                <a class="btn btn-outline-primary" asp-action="Details"
                                   asp-route-id="@item.Id">Detailhes</a>
                                <a class="btn btn-outline-primary" asp-action="Delete" asp-route-id="@item.Id">Deletar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>