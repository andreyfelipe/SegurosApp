@{
    ViewData["Title"] = "Home Page";
}


<div class="py-3">
    <h2 class="mb-4">Dashboard</h2>
    <h5 class="mb-3">Acesso Rápido</h5>
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="card-title">Seguradoras</h6>
                    <p class="card-text text-muted small">Gerencie as empresas seguradoras parceiras.</p>
                    <a asp-controller="Seguradoras" asp-action="Create" class="btn btn-sm btn-primary me-2">Nova</a>
                    <a asp-controller="Seguradoras" asp-action="Index" class="btn btn-sm btn-outline-secondary">Listar</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="card-title">Clientes</h6>
                    <p class="card-text text-muted small">Cadastre e consulte os clientes segurados.</p>
                    <a asp-controller="Clientes" asp-action="Create" class="btn btn-sm btn-success me-2">Novo</a>
                    <a asp-controller="Clientes" asp-action="Index" class="btn btn-sm btn-outline-secondary">Listar</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="card-title">Seguros</h6>
                    <p class="card-text text-muted small">Emita e gerencie os seguros.</p>
                    <a asp-controller="Seguros" asp-action="Create" class="btn btn-sm btn-info me-2">Nova</a>
                    <a asp-controller="Seguros" asp-action="Index" class="btn btn-sm btn-outline-secondary">Listar</a>
                </div>
            </div>
        </div>
    </div>
</div>
